# ==========================================
# API Keys Configuration
# ==========================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ==========================================
# Backend Configuration
# ==========================================
BACKEND_PORT=9001
BACKEND_HOST=0.0.0.0
LLM_PROVIDER=openai

# ==========================================
# Frontend Configuration
# ==========================================
VITE_API_URL=http://localhost:9001

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/foundercheck

# ==========================================
# Deployment & Local URLs
# ==========================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:9001

# ==========================================
# Auth
# ==========================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# LLM Model Configuration
# ==========================================
MODEL_NAME=gpt-3.5-turbo
MAX_TOKENS=2000
TEMPERATURE=0.7

# ==========================================
# Feature Flags
# ==========================================
ENABLE_VOICE=false
ENABLE_HALLUCINATION_CHECK=true

# ==========================================
# Development Notes
# ==========================================
# Frontend runs on: http://localhost:5173
# Backend runs on: http://localhost:9001
# Analysis time: 30-45 seconds (quick) + optional extended
# Supports: English, Bengali, Hindi
# Regions: Bangladesh, India, Pakistan, SE Asia
