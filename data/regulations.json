      "regulator": "Bangladesh Standards and Testing Institution (BSTI)",
      "category": "licensing",
      "sector": "food",
      "description": "Mandatory for food production, processing, and distribution businesses",
      "requirements": [
        "BSTI certification",
        "Food safety audit",
        "Hygiene standards compliance",
        "Product testing report"
      ],
      "fees": {
        "certification": "2000-10000 BDT",
        "renewal": "Annually"
      },
      "source_url": "https://bsti.gov.bd"
    },
    {
