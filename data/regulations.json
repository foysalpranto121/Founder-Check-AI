      "category": "licensing",
      "sector": "general",
      "description": "Required for all retail and commercial establishments in urban areas",
      "requirements": [
        "Ownership proof or lease agreement",
        "Business location address",
        "Business type classification",
        "Passport/NID of owner"
      ],
      "fees": {
        "dhaka_dncc": "500-5000 BDT per year",
        "dhaka_dscc": "500-5000 BDT per year",
        "other_cities": "200-2000 BDT per year"
      },
      "source_url": "https://dncc.gov.bd"
    },
    {
