      "id": 1,
      "title": "Corporate Income Tax Registration",
      "regulator": "National Board of Revenue (NBR)",
      "category": "tax",
      "sector": "general",
      "description": "All companies earning income in Bangladesh must register for tax with NBR and file annual returns",
      "requirements": [
        "Business registration certificate from RJSC",
        "TIN (Tax Identification Number) registration",
        "Form with company details and financial information"
      ],
      "fees": {
        "registration": "Free",
        "annual": "Based on income slab"
      },
      "source_url": "https://nbr.gov.bd"
    },
    {
      "id": 2,
      "title": "VAT Registration",
      "regulator": "National Board of Revenue (NBR)",
      "category": "tax",
      "sector": "general",
      "description": "Businesses with annual turnover above 300,000 BDT must register for VAT",
      "requirements": [
        "Annual turnover above 300,000 BDT",
        "Business registration",
        "Tax ID (TIN)"
      ],
      "fees": {
        "registration": "Free",
        "filing": "Quarterly/Monthly returns"
      },
      "source_url": "https://nbr.gov.bd"
    },
    {
      "id": 3,
      "title": "Company Registration (RJSC)",
      "regulator": "Registrar of Joint Stock Companies and Firms (RJSC)",
      "category": "registration",
      "sector": "general",
      "description": "Legal requirement to register companies with RJSC before starting operations",
      "requirements": [
        "2 shareholders minimum",
        "Memorandum and Articles of Association",
        "Initial share capital",
        "Director information"
      ],
      "fees": {
        "registration": "500-5000 BDT depending on capital",
        "processing": "7-15 days"
      },
      "source_url": "https://rjsc.gov.bd"
    },
    {
